<Window x:Class="TodoWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TodoWidget" Height="600" Width="360"
        WindowStyle="None" AllowsTransparency="True"
        Topmost="False" ShowInTaskbar="False"
        ResizeMode="CanResize" Background="Transparent">
    <WindowChrome.WindowChrome>
        <WindowChrome ResizeBorderThickness="5" GlassFrameThickness="0" CaptionHeight="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <Border Background="#E8232328" CornerRadius="8" BorderBrush="#3FFFFFFF" BorderThickness="1">
    <Grid Margin="0">
        <Grid.RowDefinitions><RowDefinition Height="40"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#2FFFFFFF" MouseLeftButtonDown="TitleBar_MouseDown">
            <TextBlock Text="待办事项" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,6,0"/>
            <Button x:Name="GroupModeBtn" Content="G" Width="26" Height="22" FontSize="10" Foreground="#88FF88" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="GroupModeBtn_Click" ToolTip="分组模式: 开" HorizontalAlignment="Left" Margin="82,0,0,0" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                <Button Content="+" Width="28" Height="28" FontSize="16" Foreground="White" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="AddBtn_Click" ToolTip="新建待办"/>
                <Button Content="g" Width="28" Height="28" FontSize="12" Foreground="#AAAAAA" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="GroupBtn_Click" ToolTip="管理分组"/>
                <Button Width="28" Height="28" FontSize="14" Foreground="#AAAAAA" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="SettingsBtn_Click" ToolTip="设置">s</Button>
                <Button Content="x" Width="28" Height="28" FontSize="14" Foreground="#FF9999" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CloseBtn_Click" ToolTip="退出"/>
            </StackPanel>
        </Grid>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl Margin="4,6,4,6" ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,4,0,0" Padding="0" CornerRadius="6" Background="#12FFFFFF">
                            <StackPanel>
                                <Grid Height="32" Background="#1AFFFFFF" MouseLeftButtonDown="GroupHeader_Click" Cursor="Hand">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ExpandIcon}" Foreground="#AAAAAA" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding GroupName}" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    <TextBlock Grid.Column="2" FontSize="11" Foreground="#777777" VerticalAlignment="Center" Margin="0,0,4,0"><Run Text="{Binding VisibleCount, Mode=OneWay}"/><Run Text=" 项"/></TextBlock>
                                    <Button Grid.Column="3" Content="+" Width="22" Height="22" FontSize="12" Foreground="#88CC88" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="GroupAddBtn_Click" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                </Grid>
                                <ItemsControl Margin="14,4,4,4" ItemsSource="{Binding Items}">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl"><Style.Triggers><DataTrigger Binding="{Binding IsExpanded}" Value="False"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,3">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" VerticalAlignment="Center" Width="20" Height="20" FontSize="8" FontWeight="Bold" Background="Transparent" BorderBrush="#888888" BorderThickness="1" Cursor="Hand" Click="ChkBtn_Click" Loaded="ChkBtn_Loaded"/>
                                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                                    <TextBlock FontSize="12" Foreground="White" TextWrapping="Wrap"><Run Text="{Binding Title}"/><Run Text=" [" Foreground="#7777CC"/><Run Text="{Binding GroupName}" Foreground="#7777CC"/><Run Text="]" Foreground="#7777CC"/></TextBlock>
                                                    <TextBlock Text="{Binding RemainingDisplay, Mode=OneWay}" FontSize="11" Foreground="#FFCC88" Margin="0,1,0,0"/>
                                                    <TextBlock FontSize="10" Foreground="#888888" Margin="0,1,0,0"><Run Text="{Binding DueDateLabel, Mode=OneWay}"/><Run Text=": "/><Run Text="{Binding DueDateDisplay, Mode=OneWay}"/></TextBlock>
                                                    <TextBlock Text="{Binding RecurringInfo, Mode=OneWay}" FontSize="10" Foreground="#88AAFF">
                                                        <TextBlock.Style><Style TargetType="TextBlock"><Style.Triggers><DataTrigger Binding="{Binding IsRecurring}" Value="False"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding AutoDeleteDisplay, Mode=OneWay}" FontSize="10" Foreground="#AA6666">
                                                        <TextBlock.Style><Style TargetType="TextBlock"><Style.Triggers><DataTrigger Binding="{Binding IsCompleted}" Value="False"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger><DataTrigger Binding="{Binding IsRecurring}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Content="e" Width="22" Height="22" FontSize="9" Foreground="#8888CC" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="EditBtn_Click"/>
                                                    <Button Content="rm" Width="22" Height="22" FontSize="9" Foreground="#FF6666" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="DeleteBtn_Click"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
    </Border>
</Window>