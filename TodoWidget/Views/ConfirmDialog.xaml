<Window x:Class="TodoWidget.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认" Height="160" Width="340"
        WindowStartupLocation="Manual" ResizeMode="NoResize" WindowStyle="ToolWindow">
    <Grid Margin="20">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock Grid.Row="0" x:Name="MessageText" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,12"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="确定" Width="80" Height="30" x:Name="OkBtn" Click="OkBtn_Click" IsDefault="True" Margin="0,0,10,0"/>
            <Button Content="取消" Width="80" Height="30" x:Name="CancelBtn" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>