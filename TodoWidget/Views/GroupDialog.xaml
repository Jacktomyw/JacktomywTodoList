<Window x:Class="TodoWidget.Views.GroupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理分组" Height="420" Width="360" WindowStartupLocation="Manual" ResizeMode="NoResize" WindowStyle="ToolWindow">
    <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="选中分组后点击按钮调整顺序" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
        <Grid Grid.Row="1" Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="NewGroupBox" Margin="0,0,6,0"/>
            <Button Grid.Column="1" Content="+ 新建" Width="66" Height="26" Click="CreateGroup_Click"/>
        </Grid>
        <ListBox Grid.Row="2" x:Name="GroupListBox" Margin="0,0,0,10" SelectionMode="Single" SelectionChanged="GroupList_SelectionChanged" MouseDoubleClick="GroupList_DoubleClick">
            <ListBox.ItemTemplate><DataTemplate><Grid Height="32"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center" FontSize="13" Margin="0,0,10,0"/>
                <Button Grid.Column="2" Content="rm" Width="28" Height="22" FontSize="10" Foreground="#FF6666" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="DeleteGroup_Click"/>
            </Grid></DataTemplate></ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="上移" Width="50" Height="28" x:Name="UpBtn" Click="UpBtn_Click" Margin="0,0,6,0" IsEnabled="False"/>
            <Button Content="下移" Width="50" Height="28" x:Name="DownBtn" Click="DownBtn_Click" Margin="0,0,6,0" IsEnabled="False"/>
            <Button Content="改名" Width="50" Height="28" x:Name="RenameBtn" Click="RenameBtn_Click" Margin="0,0,20,0" IsEnabled="False"/>
            <Button Content="关闭" Width="70" Height="28" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
